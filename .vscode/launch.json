    "version": "0.2.0",
   "configurations": [
    {
      "name": "Electron: Main",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/electron",
      "args": ["."],
      "windows": {
        "program": "${workspaceFolder}/electronApp/node_modules/electron/dist/electron.exe"
      },
      
      "outputCapture": "std",
      "runtimeArgs": [],
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal"
    }
  ]
}